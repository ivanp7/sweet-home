if [ -z "${PATH_USER:-}" ]
then
    export PATH_USER="${USER_BINARIES_PATH:-"$HOME/.local/bin"}"
    export PATH="${PATH:+"${PATH}:"}${PATH_USER}"

    [ -z "${PATH_ROOT:-}" ] || export PATH_ROOT="${PATH_ROOT:+"${PATH_ROOT}:"}${PATH_USER}"
fi

if [ -z "${LD_LIBRARY_PATH_USER:-}" ]
then
    export LD_LIBRARY_PATH_USER="${USER_LIBRARIES_PATH:-"$HOME/.local/lib"}"
    export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+"${LD_LIBRARY_PATH}:"}${LD_LIBRARY_PATH_USER}"
fi

# vim: ft=sh:
